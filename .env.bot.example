# Bot runtime configuration

# Select provider: discord or telegram
BOT_PROVIDER=telegram

# --- Discord ---
# Required if BOT_PROVIDER=discord
DISCORD_BOT_TOKEN=your_discord_bot_token_here
# Comma-separated Discord user IDs permitted to submit ideas (mandatory for Discord)
DISCORD_ALLOWED_USER_IDS=123456789
# Channel ID where the bot listens for ideas. If unset, the bot only responds to DMs.
DISCORD_IDEA_CHANNEL_ID=

# --- Telegram ---
# Required if BOT_PROVIDER=telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Comma-separated Telegram user IDs permitted to submit ideas (mandatory for Telegram)
TELEGRAM_ALLOWED_USER_IDS=123456789

# Internal backend URL (default is correct for Docker Compose)
BACKEND_URL=http://backend:8000
