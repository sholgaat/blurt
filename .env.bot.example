# Bot runtime configuration
# Provider is set automatically per-container by docker-compose.
# See .env for profile selection (telegram, discord, or both).

# --- Discord ---
DISCORD_BOT_TOKEN=your_discord_bot_token_here
# Optional: Discord channel IDs where the bot listens
# If empty, bot only responds to direct messages (DM-only mode)
# If set, bot responds to DMs AND these channels
# Format: comma-separated numeric IDs or JSON array
# Examples:
#   DISCORD_CHANNEL_IDS=123456789,987654321
#   DISCORD_CHANNEL_IDS=["123456789", "987654321"]
# DISCORD_CHANNEL_IDS=

# --- Telegram ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# --- User Authorization ---
# JSON array of allowed user IDs in format "platform:id"
# Example: ALLOWED_USER_IDS=["discord:123456789","telegram:987654321"]
ALLOWED_USER_IDS=["discord:123456789","telegram:123456789"]

# Internal backend URL (default is correct for Docker Compose)
BACKEND_URL=http://backend:8000

# Timeout for the bot waiting on the backend before replying with a timeout message
IDEA_CREATION_TIMEOUT=30
