# Backend runtime configuration

# Required for backend GitHub integration
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_REPO_OWNER=your_github_username
GITHUB_REPO_NAME=your_repository_name

# Required for backend LLM integration
GEMINI_API_KEY=your_gemini_api_key
OPENAI_API_KEY=your_openai_api_key

# Optional: set false once you have verified your setup works.
# If you run the interactive quickstart and want to enable real issue creation
# you can type the confirmation token "LIVE MODE" when prompted.
DRY_RUN=true
